# Copy to .env and fill in your values, then `source .env` (or use a dotenv loader).
# Your Chordian API key (format: on_tenant_<id>.<token>).
CHORDIAN_API_KEY=on_tenant_12345.xxxxxxxx

# Optional: service ID for credit tracking (required by Deep Research).
CHORDIAN_SERVICE_ID=

# Optional: override base URLs (e.g. for staging).
# CHORDIAN_CORE_BASE_URL=https://chordian-core.chordian.ai
# CHORDIAN_MEMORY_BASE_URL=https://graph-kb.chordian.ai
